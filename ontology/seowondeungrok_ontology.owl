  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#eventType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdfs:label xml:lang="ko">사건유형</rdfs:label>
    <rdfs:comment xml:lang="ko">사건의 세부 유형을 나타내는 관계이다. 예: 청건, 청액, 추향, 복설·훼철, 정책.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Deferred">
