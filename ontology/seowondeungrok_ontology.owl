  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#reignMonarch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">왕대</rdfs:label>
    <rdfs:comment xml:lang="ko">문건이 작성된 왕대를 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b3">
    <rdf:first rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
