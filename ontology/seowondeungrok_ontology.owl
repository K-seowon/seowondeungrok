<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Document">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">문건</rdfs:label>
    <rdfs:comment xml:lang="ko">『서원등록』에 수록된 개별 기록 단위이다. 원문, 번역문, 건명, 날짜, 왕대, 재위년 등의 속성을 지닌다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#deathYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label xml:lang="ko">몰년</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 몰년을 정수로 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#sexagenaryYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">간지</rdfs:label>
    <rdfs:comment xml:lang="ko">문건이 작성된 해의 간지를 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#lifeSpan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">생몰년</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 생몰년을 문자열로 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#concernsSeowon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b1"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon"/>
    <rdfs:label xml:lang="ko">관련서원</rdfs:label>
    <rdfs:comment xml:lang="ko">사건, 행위 또는 청원대상항목이 특정 서원과 관련되는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#isPetitionedForEnshrinementBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#petitionsForEnshrinementOf"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:range rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b8"/>
    <rdfs:label xml:lang="ko">제향되다</rdfs:label>
    <rdfs:comment xml:lang="ko">특정 인물이 청원 행위 또는 청원대상항목의 제향 대상으로 연결되는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasPetitionResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b11"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Result"/>
    <rdfs:label xml:lang="ko">청원결과</rdfs:label>
    <rdfs:comment xml:lang="ko">청원 행위 또는 청원대상항목에 대한 허가·불허·보류 등의 결과를 나타내는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#reignYearLabel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">재위년표기</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 재위년 정보를 문자열로 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#itemOfAct">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#hasPetitionItem"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#PetitionItem"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:label xml:lang="ko">청원행위에 속하다</rdfs:label>
    <rdfs:comment xml:lang="ko">청원대상항목이 특정 청원 행위에 속하는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasPetitionItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#itemOfAct"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#PetitionItem"/>
    <rdfs:label xml:lang="ko">청원대상항목을 포함하다</rdfs:label>
    <rdfs:comment xml:lang="ko">하나의 청원 행위가 하나 이상의 청원대상항목을 포함하는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#externalURL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b14"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:label xml:lang="ko">외부URL</rdfs:label>
    <rdfs:comment xml:lang="ko">인물 또는 서원에 대한 외부 참조 URL을 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasRegion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Region"/>
    <rdfs:label xml:lang="ko">소재지역</rdfs:label>
    <rdfs:label xml:lang="en">has region</rdfs:label>
    <rdfs:comment xml:lang="ko">서원이 특정 지역에 소재하는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#follows">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#precedes"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:label xml:lang="ko">(행위에)이어지다</rdfs:label>
    <rdfs:comment xml:lang="ko">어떤 행위가 다른 행위에 이어지는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b16">
    <rdf:first rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Rejected">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Result"/>
    <rdfs:label xml:lang="ko">불허</rdfs:label>
    <rdfs:label xml:lang="en">Rejected</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasExistingEnshrinedPerson">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:label xml:lang="ko">기존배향인물</rdfs:label>
    <rdfs:comment xml:lang="ko">추향 사건 당시 해당 서원·사우에 이미 배향되어 있던 인물을 나타내는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b2"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#translation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">번역문</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 한국어 번역문을 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#RoyalDesignationPetition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">청액청원</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Act">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">행위</rdfs:label>
    <rdfs:comment xml:lang="ko">사건을 구성하는 구체적 행위 단위이다. 청원, 심사, 보고, 지시, 정책 시행 등의 행위를 포함한다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#actType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:label xml:lang="ko">행위유형</rdfs:label>
    <rdfs:comment xml:lang="ko">행위의 세부 유형을 나타내는 관계이다. 예: 청건청원, 청액청원, 추향청원, 정책시행 등.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b11">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b12"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Region">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">지역</rdfs:label>
    <rdfs:comment xml:lang="ko">서원 또는 사우의 소재 지역을 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#records">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#isRecordedIn"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:label xml:lang="ko">기록하다</rdfs:label>
    <rdfs:comment xml:lang="ko">문건이 특정 행위를 기록하는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#RevokedDesignationPetition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">철액</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#locationLabel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">소재지</rdfs:label>
    <rdfs:comment xml:lang="ko">서원의 소재지를 문자열로 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">인물</rdfs:label>
    <rdfs:comment xml:lang="ko">서원 배향 대상 인물 및 문건에 등장하는 관련 인물을 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#precedes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#follows"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:label xml:lang="ko">(행위에)앞서다</rdfs:label>
    <rdfs:comment xml:lang="ko">어떤 행위가 다른 행위보다 시간적으로 앞서는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#petitionsForEnshrinementOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#isPetitionedForEnshrinementBy"/>
    <rdfs:domain rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b5"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:label xml:lang="ko">제향하다</rdfs:label>
    <rdfs:comment xml:lang="ko">청원 행위 또는 청원대상항목이 특정 인물을 제향 대상으로 삼는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Approved">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Result"/>
    <rdfs:label xml:lang="ko">허가</rdfs:label>
    <rdfs:label xml:lang="en">Approved</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Policy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">정책</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Result">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">청원결과</rdfs:label>
    <rdfs:comment xml:lang="ko">청원 행위 또는 청원대상항목의 처리 결과를 나타낸다. 허가, 불허, 보류 등을 포함한다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#AdditionalEnshrinementPetition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">추향청원</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#eventGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdfs:label xml:lang="ko">사건범주</rdfs:label>
    <rdfs:comment xml:lang="ko">사건의 큰 범주를 나타내는 관계이다. 예: 청원, 정책.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b2">
    <rdf:first rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdf:rest rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b3"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#FoundationPetition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">청건청원</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#AbolitionPetition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">훼철</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasAction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#partOfEvent"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:label xml:lang="ko">(행위를)포함하다</rdfs:label>
    <rdfs:comment xml:lang="ko">사건이 하나 이상의 행위를 포함하는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Event">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">사건</rdfs:label>
    <rdfs:comment xml:lang="ko">문건에 기록된 의미 단위이다. 청건, 청액, 추향, 복설·훼철, 정책 등 서원 관련 사안을 포괄한다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b7">
    <rdf:first rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#PetitionItem"/>
