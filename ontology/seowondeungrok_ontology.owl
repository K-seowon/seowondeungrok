  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#partOfEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#hasAction"/>
