  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hanjaName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">한자명</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 한자 이름을 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">서원</rdfs:label>
    <rdfs:comment xml:lang="ko">『서원등록』에 등장하는 서원 또는 사우를 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#birthYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label xml:lang="ko">생년</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 생년을 정수로 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#DeEnshrinementPetition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">출향</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#isRecordedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#records"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:label xml:lang="ko">기록되다</rdfs:label>
    <rdfs:comment xml:lang="ko">행위가 특정 문건에 기록되는 관계이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#AdditionalEnshrinement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">추향</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd8d592467c91478da7e1048d37bcfdb8b10">
    <rdf:first rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#PetitionItem"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#originalText">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">원문</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 한문 원문을 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#gregorianDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:label xml:lang="ko">양력</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 양력 날짜를 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#PetitionItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">청원대상항목</rdfs:label>
    <rdfs:comment xml:lang="ko">하나의 청원 행위 안에서 서원·인물·결과가 분기되는 경우, 개별 청원 대상을 분리하여 표현하기 위한 단위이다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#reignYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label xml:lang="ko">재위년</rdfs:label>
    <rdfs:comment xml:lang="ko">문건이 작성된 왕의 재위년을 정수로 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="ko">서원등록 온톨로지</rdfs:label>
    <rdfs:comment xml:lang="ko">『서원등록』 정책·청원 문건 분석을 위해 설계한 온톨로지이다. 문건, 사건, 행위, 청원대상항목, 인물, 서원, 지역, 청원결과를 주요 클래스로 설정하고, 이들 사이의 기록·포함·제향·관련서원·결과·지역 관계를 구조화한다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#PolicyExecution">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">정책시행</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#dateLabel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ko">날짜표기</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 날짜를 사람이 읽을 수 있는 문자열로 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#RS_RoyalDesignation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="ko">청액</rdfs:label>
  </rdf:Description>
