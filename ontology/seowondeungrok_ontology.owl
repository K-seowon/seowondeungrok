    <rdfs:label xml:lang="ko">건명</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 제목 또는 두주 정보를 나타낸다.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Foundation">
