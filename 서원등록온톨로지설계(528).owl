<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="ko">서원등록 온톨로지 설계-OWL스키마</rdfs:label>
    <rdfs:comment xml:lang="ko">서원등록 온톨로지 설계-OWL스키마</rdfs:comment>
  </rdf:Description>
  <!-- ==================== 1. 클래스 (Class) ==================== -->
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Document">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">문건</rdfs:label>
    <rdfs:comment xml:lang="ko">『서원등록』의 개별 기록 단위</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Event">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">사건</rdfs:label>
    <rdfs:comment xml:lang="ko">서원 관련 청원·정책 사안을 포괄하는 상위 사건</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Act">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">행위</rdfs:label>
    <rdfs:comment xml:lang="ko">사건에 속한 개별 청원·시행·처리 행위</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">인물</rdfs:label>
    <rdfs:comment xml:lang="ko">배향 대상자, 청원 주체, 정책 관련자 등 서원 관련 인물</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">서원</rdfs:label>
    <rdfs:comment xml:lang="ko">청원의 대상이 되거나 사건과 관련되는 서원</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Region">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">지역</rdfs:label>
    <rdfs:comment xml:lang="ko">서원의 소재지 및 행정 구역</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#Result">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">청원결과</rdfs:label>
    <rdfs:comment xml:lang="ko">청원 행위 또는 청원대상항목에 대한 허가·불허 등의 청원 결과</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#PetitionItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">청원대상항목</rdfs:label>
    <rdfs:comment xml:lang="ko">하나의 청원 행위 안에서 인물별·서원별 심사 대상을 구분하기 위한 단위</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#ActTypeValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">행위유형값</rdfs:label>
    <rdfs:comment xml:lang="ko">actType 속성의 값으로 쓰이는 분류값 항목</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#EventTypeValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">사건유형값</rdfs:label>
    <rdfs:comment xml:lang="ko">eventType 속성의 값으로 쓰이는 분류값 항목</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#EventGroupValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="ko">사건범주값</rdfs:label>
    <rdfs:comment xml:lang="ko">eventGroup 속성의 값으로 쓰이는 분류값 항목</rdfs:comment>
  </rdf:Description>
  <!-- ==================== 2. 데이터속성 (Datatype Property) ==================== -->
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#headnote">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">건명</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 건명을 나타내는 데이터 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#gregorianDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">양력</rdfs:label>
    <rdfs:comment xml:lang="ko">문건, 행위, 사건 등 날짜 정보를 지닐 수 있는 개체의 날짜를 정렬·필터링 가능한 양력 날짜 형식으로 나타내는 데이터 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#dateLabel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">날짜표기</rdfs:label>
    <rdfs:comment xml:lang="ko">문건, 행위, 사건 등 날짜 정보를 지닐 수 있는 개체의 날짜를 사람이 읽을 수 있는 형태로 나타내는 데이터 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#reignYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">재위년</rdfs:label>
    <rdfs:comment xml:lang="ko">문건, 행위, 사건 등 재위년 정보를 지닐 수 있는 개체의 재위년을 숫자값으로 나타내는 데이터 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#reignYearLabel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">재위년표기</rdfs:label>
    <rdfs:comment xml:lang="ko">문건, 행위, 사건 등 재위년 정보를 지닐 수 있는 개체의 재위년을 표시용 문자열로 나타내는 데이터 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#reignMonarch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">왕대</rdfs:label>
    <rdfs:comment xml:lang="ko">문건, 행위, 사건 등 왕대 정보를 지닐 수 있는 개체의 왕대를 나타내는 데이터 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#sexagenaryYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">간지</rdfs:label>
    <rdfs:comment xml:lang="ko">문건, 행위, 사건 등 간지 정보를 지닐 수 있는 개체의 간지를 나타내는 데이터 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#originalText">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">원문</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 한문 원문 내용을 나타내는 데이터 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#translation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">번역문</rdfs:label>
    <rdfs:comment xml:lang="ko">문건의 번역문을 나타내는 데이터 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hanjaName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">한자명</rdfs:label>
    <rdfs:comment xml:lang="ko">인물, 서원, 지역 등 여러 개체의 한자 표기를 나타내는 데이터 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#birthYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">생년</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 출생 연도를 숫자값으로 나타내는 데이터 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#deathYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">몰년</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 사망 연도를 숫자값으로 나타내는 데이터 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#lifeSpan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">생몰년</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 생년과 몰년을 표시용 문자열로 나타내는 데이터 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#locationLabel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">소재지</rdfs:label>
    <rdfs:comment xml:lang="ko">서원의 소재지를 문자열로 나타내는 데이터 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#externalURL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="ko">외부URL</rdfs:label>
    <rdfs:comment xml:lang="ko">인물, 서원, 문건, 사건 등 여러 개체와 관련된 외부 참조 URL을 나타내는 데이터 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
  </rdf:Description>
  <!-- ==================== 3. 관계속성 (Object Property) ==================== -->
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#records">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">기록하다</rdfs:label>
    <rdfs:comment xml:lang="ko">문건이 특정 행위를 기록하고 있음을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#isRecordedIn"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#isRecordedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">기록되다</rdfs:label>
    <rdfs:comment xml:lang="ko">특정 행위가 문건에 기록되어 있음을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Document"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasAction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">행위를 포함하다</rdfs:label>
    <rdfs:comment xml:lang="ko">사건이 이에 속하는 개별 행위를 포함함을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#partOfEvent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#partOfEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">사건에 속하다</rdfs:label>
    <rdfs:comment xml:lang="ko">개별 행위가 특정 사건에 속함을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#precedes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">행위에 앞서다</rdfs:label>
    <rdfs:comment xml:lang="ko">동일 사건 내에서 한 행위가 다른 행위보다 시간적으로 앞섬을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#follows"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#follows">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">행위에 이어지다</rdfs:label>
    <rdfs:comment xml:lang="ko">동일 사건 내에서 한 행위가 다른 행위 뒤에 이어짐을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#eventGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">사건범주</rdfs:label>
    <rdfs:comment xml:lang="ko">사건이 청원 또는 정책 중 어느 범주에 속하는지를 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#EventGroupValue"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#eventType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">사건유형</rdfs:label>
    <rdfs:comment xml:lang="ko">사건이 청건, 청액, 추향, 복설훼철, 정책 등 어느 유형에 속하는지를 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#EventTypeValue"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#actType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">행위유형</rdfs:label>
    <rdfs:comment xml:lang="ko">행위가 청건청원, 청액청원, 추향청원, 정책시행 등 어느 유형에 속하는지를 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#ActTypeValue"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasPetitionResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">청원결과</rdfs:label>
    <rdfs:comment xml:lang="ko">청원 행위, 사건, 청원대상항목 등에 부여되는 허가·불허·보류 등의 청원 결과를 나타내는 관계 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Result"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasPetitionItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">청원대상항목을 포함하다</rdfs:label>
    <rdfs:comment xml:lang="ko">하나의 청원 행위가 인물별·서원별 청원대상항목을 포함함을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#PetitionItem"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#itemOfAct"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#itemOfAct">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">청원행위에 속하다</rdfs:label>
    <rdfs:comment xml:lang="ko">청원대상항목이 특정 청원 행위에 속함을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#PetitionItem"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Act"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#petitionsForEnshrinementOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">제향하다</rdfs:label>
    <rdfs:comment xml:lang="ko">청원 행위 또는 청원대상항목이 특정 인물을 제향 대상으로 삼는 관계 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#isPetitionedForEnshrinementBy"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#isPetitionedForEnshrinementBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">제향되다</rdfs:label>
    <rdfs:comment xml:lang="ko">특정 인물이 청원 행위 또는 청원대상항목의 제향 대상으로 연결되는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
    <owl:inverseOf rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#petitionsForEnshrinementOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasExistingEnshrinedPerson">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">기존배향인물</rdfs:label>
    <rdfs:comment xml:lang="ko">추향 사건 당시 해당 서원·사우에 이미 배향되어 있던 인물</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Event"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Person"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#concernsSeowon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">관련서원</rdfs:label>
    <rdfs:comment xml:lang="ko">사건, 행위 또는 청원대상항목이 특정 서원과 관련되는 관계 속성</rdfs:comment>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://dh.aks.ac.kr/ontology/seowondeungrok#hasRegion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="ko">소재지역</rdfs:label>
    <rdfs:comment xml:lang="ko">서원이 위치한 지역을 나타내는 관계 속성</rdfs:comment>
    <rdfs:domain rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Seowon"/>
    <rdfs:range rdf:resource="http://dh.aks.ac.kr/ontology/seowondeungrok#Region"/>
  </rdf:Description>
</rdf:RDF>
