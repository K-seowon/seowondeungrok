@prefix : <http://dh.aks.ac.kr/ontologies/seowondeungrok#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix seowon: <http://dh.aks.ac.kr/ontologies/seowondeungrok#> .
@base <http://dh.aks.ac.kr/ontologies/seowondeungrok#> .

<http://dh.aks.ac.kr/ontologies/seowondeungrok> rdf:type owl:Ontology .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://dh.aks.ac.kr/ontologies/seowondeungrok#actType
seowon:actType rdf:type owl:ObjectProperty ;
               rdfs:domain seowon:Act ;
               rdfs:label "행위유형"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#concernsSeowon
seowon:concernsSeowon rdf:type owl:ObjectProperty ;
                      rdfs:domain seowon:Event ;
                      rdfs:range seowon:Seowon ;
                      rdfs:comment "사건, 행위 또는 청원대상항목이 특정 서원과 관련되는 관계 속성"@ko ;
                      rdfs:label "관련서원"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#eventGroup
seowon:eventGroup rdf:type owl:ObjectProperty ;
                  rdfs:domain seowon:Event ;
                  rdfs:label "사건범주"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#eventType
seowon:eventType rdf:type owl:ObjectProperty ;
                 rdfs:domain seowon:Event ;
                 rdfs:label "사건유형"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#follows
seowon:follows rdf:type owl:ObjectProperty ;
               owl:inverseOf seowon:precedes ;
               rdfs:domain seowon:Act ;
               rdfs:range seowon:Act ;
               rdfs:label "(행위에)이어지다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#hasAction
seowon:hasAction rdf:type owl:ObjectProperty ;
                 owl:inverseOf seowon:partOfEvent ;
                 rdfs:domain seowon:Event ;
                 rdfs:range seowon:Act ;
                 rdfs:label "(행위를)포함하다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#hasExistingEnshrinedPerson
seowon:hasExistingEnshrinedPerson rdf:type owl:ObjectProperty ;
                                  rdfs:domain seowon:Event ;
                                  rdfs:range seowon:Person ;
                                  rdfs:comment "추향 사건 당시 해당 서원·사우에 이미 배향되어 있던 인물"@ko ;
                                  rdfs:label "기존배향인물"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#hasPetitionItem
seowon:hasPetitionItem rdf:type owl:ObjectProperty ;
                       owl:inverseOf seowon:itemOfAct ;
                       rdfs:domain seowon:Act ;
                       rdfs:range seowon:PetitionItem ;
                       rdfs:label "청원대상항목을 포함하다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#hasPetitionResult
seowon:hasPetitionResult rdf:type owl:ObjectProperty ;
                         rdfs:domain seowon:Act ,
                                     seowon:PetitionItem ;
                         rdfs:range seowon:Result ;
                         rdfs:comment "청원 행위 또는 청원대상항목에 대한 허가·불허 등의 청원 결과를 나타내는 관계 속성"@ko ;
                         rdfs:label "청원결과"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#hasRegion
seowon:hasRegion rdf:type owl:ObjectProperty ;
                 rdfs:domain seowon:Seowon ;
                 rdfs:range seowon:Region ;
                 rdfs:label "has region"@en ,
                            "소재지역"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#isPetitionedForEnshrinementBy
seowon:isPetitionedForEnshrinementBy rdf:type owl:ObjectProperty ;
                                     owl:inverseOf seowon:petitionsForEnshrinementOf ;
                                     rdfs:domain seowon:Person ;
                                     rdfs:comment "특정 인물이 청원 행위 또는 청원대상항목의 제향 대상으로 연결되는 관계 속성"@ko ;
                                     rdfs:label "제향되다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#isRecordedIn
seowon:isRecordedIn rdf:type owl:ObjectProperty ;
                    owl:inverseOf seowon:records ;
                    rdfs:domain seowon:Act ;
                    rdfs:range seowon:Document ;
                    rdfs:label "기록되다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#itemOfAct
seowon:itemOfAct rdf:type owl:ObjectProperty ;
                 rdfs:domain seowon:PetitionItem ;
                 rdfs:range seowon:Act ;
                 rdfs:label "청원행위에 속하다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#partOfEvent
seowon:partOfEvent rdf:type owl:ObjectProperty ;
                   rdfs:domain seowon:Act ;
                   rdfs:range seowon:Event ;
                   rdfs:label "(사건에)속하다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#petitionsForEnshrinementOf
seowon:petitionsForEnshrinementOf rdf:type owl:ObjectProperty ;
                                  rdfs:domain seowon:Act ,
                                              seowon:PetitionItem ;
                                  rdfs:range seowon:Person ;
                                  rdfs:comment "청원 행위 또는 청원대상항목이 특정 인물을 제향 대상으로 삼는 관계 속성"@ko ;
                                  rdfs:label "제향하다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#precedes
seowon:precedes rdf:type owl:ObjectProperty ;
                rdfs:domain seowon:Act ;
                rdfs:range seowon:Act ;
                rdfs:label "(행위에)앞서다"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#records
seowon:records rdf:type owl:ObjectProperty ;
               rdfs:domain seowon:Document ;
               rdfs:range seowon:Act ;
               rdfs:label "기록하다"@ko .


#################################################################
#    Data properties
#################################################################

###  http://dh.aks.ac.kr/ontologies/seowondeungrok#birthYear
seowon:birthYear rdf:type owl:DatatypeProperty ;
                 rdfs:domain seowon:Person ;
                 rdfs:range xsd:integer ;
                 rdfs:label "생년"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#dateLabel
seowon:dateLabel rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
                 rdfs:label "날짜표기"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#deathYear
seowon:deathYear rdf:type owl:DatatypeProperty ;
                 rdfs:domain seowon:Person ;
                 rdfs:range xsd:integer ;
                 rdfs:label "몰년"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#externalURL
seowon:externalURL rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:anyURI ;
                   rdfs:label "외부URL"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#gregorianDate
seowon:gregorianDate rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:date ;
                     rdfs:label "양력"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#hanjaName
seowon:hanjaName rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
                 rdfs:label "한자명"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#headnote
seowon:headnote rdf:type owl:DatatypeProperty ;
                rdfs:domain seowon:Document ;
                rdfs:range xsd:string ;
                rdfs:label "건명"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#lifeSpan
seowon:lifeSpan rdf:type owl:DatatypeProperty ;
                rdfs:domain seowon:Person ;
                rdfs:range xsd:string ;
                rdfs:label "생몰년"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#locationLabel
seowon:locationLabel rdf:type owl:DatatypeProperty ;
                     rdfs:domain seowon:Seowon ;
                     rdfs:range xsd:string ;
                     rdfs:label "소재지"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#originalText
seowon:originalText rdf:type owl:DatatypeProperty ;
                    rdfs:domain seowon:Document ;
                    rdfs:range xsd:string ;
                    rdfs:label "원문"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#reignMonarch
seowon:reignMonarch rdf:type owl:DatatypeProperty ;
                    rdfs:range xsd:string ;
                    rdfs:label "왕대"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#reignYear
seowon:reignYear rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:integer ;
                 rdfs:label "재위년"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#reignYearLabel
seowon:reignYearLabel rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:string ;
                      rdfs:label "재위년표기"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#sexagenaryYear
seowon:sexagenaryYear rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:string ;
                      rdfs:label "간지"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#translation
seowon:translation rdf:type owl:DatatypeProperty ;
                   rdfs:domain seowon:Document ;
                   rdfs:range xsd:string ;
                   rdfs:label "번역문"@ko .


#################################################################
#    Classes
#################################################################

###  http://dh.aks.ac.kr/ontologies/seowondeungrok#Act
seowon:Act rdf:type owl:Class ;
           rdfs:label "행위"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#Document
seowon:Document rdf:type owl:Class ;
                rdfs:label "문건"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#Event
seowon:Event rdf:type owl:Class ;
             rdfs:label "사건"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#Person
seowon:Person rdf:type owl:Class ;
              rdfs:label "인물"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#PetitionItem
seowon:PetitionItem rdf:type owl:Class ;
                    rdfs:label "청원대상항목"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#Region
seowon:Region rdf:type owl:Class ;
              rdfs:label "지역"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#Result
seowon:Result rdf:type owl:Class ;
              rdfs:label "청원결과"@ko .


###  http://dh.aks.ac.kr/ontologies/seowondeungrok#Seowon
seowon:Seowon rdf:type owl:Class ;
              rdfs:label "서원"@ko .


