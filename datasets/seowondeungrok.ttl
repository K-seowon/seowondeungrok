#    Individuals
#################################################################

###  http://dh.aks.ac.kr/ontologies/seowondeungrok#AE1
seowon:AE1 rdf:type owl:NamedIndividual ,
                    seowon:Event ;
           seowon:concernsSeowon seowon:S176 ;
           seowon:eventGroup seowon:Petition ;
           seowon:eventType seowon:AdditionalEnshrinement ;
           seowon:hasAction seowon:AE1_Pet1 ,
                            seowon:AE1_Pet1_Review1 ,
                            seowon:AE1_Pet1_Review2 ;
